@page
@model Andrey_LibreModel

@section Styles {
    <link rel="stylesheet" href="~/css/AndreyLibre.css" />
}

<section class="hero">
    <h1>Andrey Calderón Vega</h1>
    <p class="hero-subtitle">
        Desarrollador TI · Bases de Datos · Big Data
    </p>
</section>

<section id="sobre" class="seccion">
    <h2>Sobre mí</h2>
    <p>
        Soy estudiante de Tecnologías de la Información y Big Data en el Colegio Universitario de Cartago (CUC),
        con interés en el desarrollo de software, bases de datos y análisis de datos.
    </p>
</section>

<section id="formacion" class="seccion gris">
    <h2>Formación Académica</h2>

    <div class="card">
        <h3>Tecnologías de la Información</h3>
        <p>CUC – Último cuatrimestre</p>
    </div>

    <div class="card">
        <h3>Big Data</h3>
        <p>CUC – 4° cuatrimestre</p>
    </div>
</section>

<section id="habilidades" class="seccion">
    <h2>Habilidades Técnicas</h2>
    <ul class="lista">
        <li>HTML, CSS, JavaScript</li>
        <li>Python, Java, C#</li>
        <li>SQL Server, MySQL, MongoDB</li>
        <li>Big Data & Análisis con R</li>
        <li>Ciberseguridad</li>
    </ul>
</section>

<section id="proyectos" class="seccion gris">
    <h2>Proyectos Destacados</h2>

    <div class="proyectos">
        <div class="card">
            <h3>Sistema de Recursos Humanos</h3>
            <p>ASP.NET MVC con arquitectura en capas.</p>
        </div>

        <div class="card">
            <h3>Chatbot Javi</h3>
            <p>Asistente virtual con API de OpenAI.</p>
        </div>

        <div class="card">
            <h3>Big Data Cartago</h3>
            <p>Análisis estadístico con R y clustering PAM.</p>
        </div>
    </div>
</section>